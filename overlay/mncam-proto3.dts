/dts-v1/;
/plugin/;

/ {
	compatible = "brcm,bcm2711";


	fragment@0 {
		target = <&i2s_clk_producer>;
		__overlay__ {
			status = "okay";
		};
	};

	fragment@1 {
		target = <&i2c1>;
		__overlay__ {
			#address-cells = <1>;
			#size-cells = <0>;
			status = "okay";

			mncam_adc: pcm186x@4a {
				#sound-dai-cells = <0>;
				compatible = "ti,pcm1862";
				reg = <0x4a>;
				status = "okay";
			};
		};
	};

    fragment@2 {
        target = <&sound>;
        __overlay__ {
            compatible = "simple-audio-card";
            i2s-controller = <&i2s_clk_producer>;
            simple-audio-card,name = "mncam";
            simple-audio-card,format = "i2s";

            status = "okay";

            simple-audio-card,cpu {
                sound-dai = <&i2s>;
                dai-tdm-slot-num = <2>;
                dai-tdm-slot-width = <32>;
            };

            simple-audio-card,codec {
                sound-dai = <&mncam_adc>;
            };
        };
    };
};
